{
  "name": "magicstack-api-template",
  "version": "1.0.0",
  "description": "MagicStack API Starter Template",
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-files",
    "copy-files": "node -e \"require('fs').cpSync('package.json', 'dist/package.json'); require('fs').cpSync('.env', 'dist/.env')\"",
    "start": "node dist/index.js",
    "deploy": "node scripts/deploy.js",
    "publish": "npm run build && npm run deploy",
    "dev": "nodemon --watch src --ext ts,js --exec \"ts-node -r dotenv/config src/index.ts\""
  },
  "dependencies": {
    "basic-ftp": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.16.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mysql": "^2.15.27",
    "@types/node": "^20.10.6",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
